{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/payment/[slug]",
      "regex": "^/payment/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/payment/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/achievements",
      "regex": "^/achievements(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/achievements(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/dashboard",
      "regex": "^/admin/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/dashboard(?:/)?$"
    },
    {
      "page": "/admin/login",
      "regex": "^/admin/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/login(?:/)?$"
    },
    {
      "page": "/admin/setup",
      "regex": "^/admin/setup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/setup(?:/)?$"
    },
    {
      "page": "/payment/free-rank",
      "regex": "^/payment/free\\-rank(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/payment/free\\-rank(?:/)?$"
    },
    {
      "page": "/payment/instruction",
      "regex": "^/payment/instruction(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/payment/instruction(?:/)?$"
    },
    {
      "page": "/payment/success",
      "regex": "^/payment/success(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/payment/success(?:/)?$"
    },
    {
      "page": "/profile",
      "regex": "^/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/profile(?:/)?$"
    },
    {
      "page": "/server-info",
      "regex": "^/server\\-info(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/server\\-info(?:/)?$"
    },
    {
      "page": "/social",
      "regex": "^/social(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/social(?:/)?$"
    },
    {
      "page": "/staff",
      "regex": "^/staff(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/staff(?:/)?$"
    },
    {
      "page": "/store",
      "regex": "^/store(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/store(?:/)?$"
    },
    {
      "page": "/team",
      "regex": "^/team(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/team(?:/)?$"
    },
    {
      "page": "/tutorial",
      "regex": "^/tutorial(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tutorial(?:/)?$"
    },
    {
      "page": "/vote",
      "regex": "^/vote(?:/)?$",
